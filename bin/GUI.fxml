<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller">
   <children>
      <VBox prefHeight="400.0" prefWidth="600.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <ListView fx:id="passwordListView" prefHeight="310.0" VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER" prefHeight="90.0" prefWidth="600.0" spacing="30.0">
               <children>
                  <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Label text="Password Length" />
                        <Spinner fx:id="passwordLength" editable="true" prefHeight="35.0" prefWidth="120.0" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Label prefHeight="17.0" prefWidth="88.0" text="Password Count" />
                        <Spinner fx:id="passwordCount" editable="true" prefHeight="35.0" prefWidth="267.0" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Label fx:id="copyAlert" prefHeight="17.0" prefWidth="132.0" text="Copied password #10000!" visible="false" />
                        <Button mnemonicParsing="false" onAction="#generate" prefHeight="35.0" prefWidth="100.0" text="Generate" textAlignment="CENTER" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Label fx:id="exportAlert" text="Exported!" visible="false" />
                        <Button mnemonicParsing="false" onAction="#export" prefHeight="35.0" prefWidth="120.0" text="Export to .txt" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
